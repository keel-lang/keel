# Inbox Assistant — environment configuration.
#
# Copy this file to `.env`, fill in real values, and source it
# before running the example:
#
#   cp .env.example .env
#   set -a && source .env && set +a
#   keel run inbox_assistant.keel
#
# Every variable below is optional. The program degrades gracefully
# when something isn't set — Email.fetch returns an empty list,
# Ai.* falls back to deterministic defaults, Http.post is skipped
# when no webhook URL is present.


# ─── LLM (Ollama) ───────────────────────────────────────────────────

# Base URL of your Ollama server. Defaults to localhost:11434 when
# unset. Most users won't need to change this.
OLLAMA_HOST=http://localhost:11434

# Default model for every Ai.* call that resolves to "default"
# (i.e., no `@model` on the agent and no `using:` override).
# Must correspond to a tag available in `ollama list`.
KEEL_OLLAMA_MODEL=llama3

# Per-alias model map. `KEEL_MODEL_<ALIAS>=<ollama_tag>` lets you
# reference a Keel-side alias via the `using:` argument:
#
#   Ai.classify(body, as: Urgency, using: "fast")
#   Ai.draft(prompt, using: "smart")
#
# The alias name is case-insensitive and underscores map to hyphens.
KEEL_MODEL_FAST=gemma:2b
KEEL_MODEL_SMART=mistral:7b-instruct

# Set to `mock` to short-circuit every Ai.* call (useful for tests
# and offline dev). When mock, each call returns `none` / `[]` and
# the agent falls through to its `fallback:` values.
# KEEL_LLM=mock


# ─── Email (IMAP + SMTP) ────────────────────────────────────────────

# Required for Email.fetch. Without these, fetch returns [] and the
# assistant just polls empty. Gmail users typically use an app
# password here, not the account password.
IMAP_HOST=imap.gmail.com
EMAIL_USER=you@example.com
EMAIL_PASS=your-app-password

# SMTP host for Email.send. If omitted, the runtime derives it from
# IMAP_HOST by replacing `imap.` with `smtp.`, which works for Gmail,
# Fastmail, and many providers. Override for anything non-standard.
# SMTP_HOST=smtp.gmail.com


# ─── App-specific config (read by the agent via Env.get/require) ──

# Address that critical escalations are sent to. Defaults to
# ops@example.com when unset.
ESCALATE_TO=ops@example.com

# Language for the daily digest. Ai.translate is invoked when this
# is anything other than `english`.
DIGEST_LANG=english

# Absolute time for the daily digest (RFC 3339 / ISO 8601). Pick a
# time in the future; if the value is in the past, Schedule.at fires
# immediately on boot.
DIGEST_AT=2026-04-19T09:00:00Z

# Optional webhook endpoint to POST the daily digest JSON to. Leave
# unset to skip the HTTP hop entirely.
# DIGEST_WEBHOOK=https://hooks.example.com/keel-digest
# DIGEST_TOKEN=sk-secretbearer
