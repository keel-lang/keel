# ============================================================
# Keel — Hello World
# ============================================================
# The simplest possible agent: greets you and answers questions.
# ============================================================

agent Hello {
  role "You are a friendly assistant who greets people warmly"
  model "claude-haiku"

  on message(msg: Message) {
    reply = draft "response to {msg}" {
      tone: "warm"
    }
    show user reply
  }
}

run Hello
